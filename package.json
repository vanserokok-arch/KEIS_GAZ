{
  "name": "keis-contract-system",
  "version": "0.1.0",
  "description": "KEIS Contract System MVP",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 tsx src/main/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "check:renderer-base": "tsx scripts/check-renderer-base.ts",
    "smoke": "tsx scripts/smoke.ts",
    "dist:win": "npm run build && electron-builder --win"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "keis"
  ],
  "author": "Codex",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "ru.keis.contract-system",
    "productName": "KEIS Contract System",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "docx": "^9.5.1",
    "electron": "^37.7.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
